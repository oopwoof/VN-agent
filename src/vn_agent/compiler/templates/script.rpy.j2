# {{ script.title }}
# Generated by VN-Agent

label start:
    jump {{ script.start_scene_id }}

{% set ns = namespace(current_music=None) %}
{% for scene in script.scenes %}
label {{ scene.id }}:
{% if scene.music %}
{% set music_path = scene.music.file_path if scene.music.file_path else ("audio/bgm/" + scene.music.mood.value + ".ogg") %}
{% if music_path != ns.current_music %}
    play music "{{ music_path }}" fadein {{ scene.music.fade_in }}
{% set ns.current_music = music_path %}
{% endif %}
{% elif scene.music is none and ns.current_music %}
    stop music fadeout 1.0
{% set ns.current_music = None %}
{% endif %}
{% if loop.first %}
    scene {{ scene.background_id }} with fade
{% else %}
    scene {{ scene.background_id }} with dissolve
{% endif %}
{% set positions = ['vn_sprite_center'] if scene.characters_present|length == 1 else ['vn_sprite_left', 'vn_sprite_right'] if scene.characters_present|length == 2 else ['vn_sprite_left', 'vn_sprite_center', 'vn_sprite_right'] %}
{% for char_id in scene.characters_present %}
    show {{ char_id }} neutral at {{ positions[loop.index0 % positions|length] }}
{% endfor %}

{% set ns_emo = namespace(map={}) %}
{% for line in scene.dialogue %}
{% if line.character_id %}
{% if line.emotion != ns_emo.map.get(line.character_id, 'neutral') %}
    show {{ line.character_id }} {{ line.emotion }}
{% set _ = ns_emo.map.update({line.character_id: line.emotion}) %}
{% endif %}
    {{ line.character_id }} "{{ line.text | renpy_safe }}"
{% else %}
    "{{ line.text | renpy_safe }}"
{% endif %}
{% endfor %}

{# Sprint 9-4: apply state_writes at scene end before jump/menu/return #}
{% if scene.state_writes %}
{% for var, val in scene.state_writes.items() %}
{% if val is string %}
    $ {{ var }} = "{{ val }}"
{% elif val is sameas true %}
    $ {{ var }} = True
{% elif val is sameas false %}
    $ {{ var }} = False
{% else %}
    $ {{ var }} = {{ val }}
{% endif %}
{% endfor %}
{% endif %}
{% if scene.branches %}
    menu:
{% for branch in scene.branches %}
{% if branch.requires %}
{# Sprint 9-1: symbolic visibility guard — branch only shown when state matches #}
{% set guard_parts = [] %}
{% for req_var, req_val in branch.requires.items() %}
{% if req_val is string %}{% set _ = guard_parts.append(req_var ~ ' == "' ~ req_val ~ '"') %}
{% elif req_val is sameas true %}{% set _ = guard_parts.append(req_var) %}
{% elif req_val is sameas false %}{% set _ = guard_parts.append('not ' ~ req_var) %}
{% else %}{% set _ = guard_parts.append(req_var ~ ' == ' ~ req_val) %}
{% endif %}
{% endfor %}
        "{{ branch.text | renpy_safe }}" if {{ guard_parts | join(' and ') }}:
            jump {{ branch.next_scene_id }}
{% else %}
        "{{ branch.text | renpy_safe }}":
            jump {{ branch.next_scene_id }}
{% endif %}
{% endfor %}
{% elif scene.next_scene_id %}
    jump {{ scene.next_scene_id }}
{% else %}
    return
{% endif %}

{% endfor %}
