# {{ script.title }}
# Generated by VN-Agent

label start:
    jump {{ script.start_scene_id }}

{% set ns = namespace(current_music=None) %}
{% for scene in script.scenes %}
label {{ scene.id }}:
{% if scene.music %}
{% set music_path = scene.music.file_path if scene.music.file_path else ("audio/bgm/" + scene.music.mood.value + ".ogg") %}
{% if music_path != ns.current_music %}
    play music "{{ music_path }}" fadein {{ scene.music.fade_in }}
{% set ns.current_music = music_path %}
{% endif %}
{% elif scene.music is none and ns.current_music %}
    stop music fadeout 1.0
{% set ns.current_music = None %}
{% endif %}
{% if loop.first %}
    scene {{ scene.background_id }} with fade
{% else %}
    scene {{ scene.background_id }} with dissolve
{% endif %}
{% set positions = ['center'] if scene.characters_present|length == 1 else ['left', 'right'] if scene.characters_present|length == 2 else ['left', 'center', 'right'] %}
{% for char_id in scene.characters_present %}
    show {{ char_id }} neutral at {{ positions[loop.index0 % positions|length] }}
{% endfor %}

{% set ns_emo = namespace(map={}) %}
{% for line in scene.dialogue %}
{% if line.character_id %}
{% if line.emotion != ns_emo.map.get(line.character_id, 'neutral') %}
    show {{ line.character_id }} {{ line.emotion }}
{% set _ = ns_emo.map.update({line.character_id: line.emotion}) %}
{% endif %}
    {{ line.character_id }} "{{ line.text | replace('"', '\\"') }}"
{% else %}
    "{{ line.text | replace('"', '\\"') }}"
{% endif %}
{% endfor %}

{% if scene.branches %}
    menu:
{% for branch in scene.branches %}
        "{{ branch.text | replace('"', '\\"') }}":
            jump {{ branch.next_scene_id }}
{% endfor %}
{% elif scene.next_scene_id %}
    jump {{ scene.next_scene_id }}
{% else %}
    return
{% endif %}

{% endfor %}
