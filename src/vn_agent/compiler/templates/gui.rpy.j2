## GUI Configuration — {{ script.title | renpy_safe }}
## Generated by VN-Agent
##
## Design strategy (post-Sprint 12-3e simplification):
## We STOPPED overriding Ren'Py's built-in `screen say` + `style window`.
## Every attempt to rebuild the dialogue box from scratch (custom
## nameplate frame, scoped say_window style, gradient backdrop) either
## collided with Ren'Py's style inheritance (dialog box disappeared)
## or left save/load/preferences screens in a half-styled state.
##
## Current approach: customize ONLY via `define gui.*` knobs (colors,
## font sizes, padding, textbox background image). Ren'Py's stock say
## screen picks these up via the usual channels and renders correctly.
## We DO keep a custom `screen choice` because the default menu
## (stacked buttons in the textbox) was the user's specific complaint.

init python:
    config.name = "{{ script.title | renpy_safe }}"
    config.version = "1.0"
    config.window_title = "{{ script.title | renpy_safe }}"

## ── Textbox ────────────────────────────────────────────────────────
define gui.textbox_height = 300
define gui.textbox_yalign = 1.0

## A solid dark panel at ~80% alpha. Ren'Py's `gui.textbox_background`
## accepts any displayable — we give it a single flat Solid so the
## textbox reads as a clean bar at the bottom of the screen rather
## than a visible frame with borders.
define gui.textbox_background = Solid("#0a0f14cc")

## ── Dialogue body ──────────────────────────────────────────────────
define gui.text_color = "#f2ecdc"
define gui.text_font = "DejaVuSans.ttf"
define gui.text_size = 26
define gui.text_xpos = 280
define gui.text_ypos = 60
define gui.text_width = 1360
define gui.text_line_spacing = 6
define gui.text_outlines = [(2, "#000000c8", 0, 0)]

## ── Speaker name ───────────────────────────────────────────────────
## Speaker color comes from the per-Character(color=...) define. These
## are the FALLBACK colors + font metrics used when Ren'Py's stock
## name layout kicks in (left of the dialogue body).
define gui.name_text_font = "DejaVuSans.ttf"
define gui.name_text_size = 30
define gui.name_text_color = "#e8d49a"
define gui.name_text_outlines = [(2, "#000000d8", 0, 0)]
define gui.name_text_xpos = 80
define gui.name_text_ypos = 14
define gui.name_text_xalign = 0.0

## ── Punctuation-aware typewriter ──────────────────────────────────
## Ren'Py's {w=N} tag pauses N seconds. A filter post-processes Writer
## output to insert these automatically around strong punctuation —
## gives the AI's dialogue natural breathing without Writer needing
## to emit timing tags itself.
init python:
    import re
    _PUNCT_PAUSE = [
        (r"\.\.\.", r"...{w=0.45}"),
        (r"([。！？])", r"\1{w=0.35}"),
        (r"([,，])", r"\1{w=0.12}"),
        (r"([.!?])\s+(?=[A-Z])", r"\1{w=0.25} "),
    ]
    def _vn_typewriter_pauses(s):
        for pattern, repl in _PUNCT_PAUSE:
            s = re.sub(pattern, repl, s)
        return s
    config.say_menu_text_filter = _vn_typewriter_pauses

define _preferences.text_cps = 50

## ── Custom choice screen ───────────────────────────────────────────
## Player-facing branches render as floating buttons stacked in the
## middle of the screen, NOT inside the dialogue box. The backdrop
## dims to ~60% so focus jumps to the choices without hiding the
## scene entirely (player remembers what prompted the decision).
screen choice(items):
    style_prefix "vn_choice"

    add Solid("#000000a0")

    vbox:
        xalign 0.5
        yalign 0.5
        spacing 28

        for i in items:
            textbutton i.caption:
                action i.action
                style "vn_choice_button"

style vn_choice_button is default:
    background Frame(Solid("#1a2030e8"), 40, 20)
    hover_background Frame(Solid("#3a4a70f0"), 40, 20)
    padding (48, 22)
    xsize 900
    xalign 0.5

style vn_choice_button_text is default:
    font gui.text_font
    size 28
    color "#e8d49a"
    hover_color "#ffe8a0"
    outlines [(2, "#000000d8", 0, 0)]
    xalign 0.5
    text_align 0.5
