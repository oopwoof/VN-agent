## GUI Configuration — {{ script.title }}
## Generated by VN-Agent
##
## Borrows the tasteful-minimum aesthetic from Umineko / The House in
## Fata Morgana: a dark translucent textbox at the bottom ~28% of the
## screen, a narrow accent bar separating the speaker tag from the
## body, generous line-height. No decorative frames — the backdrop is
## strong enough on its own.

init python:
    config.name = "{{ script.title }}"
    config.version = "1.0"
    config.window_title = "{{ script.title }}"

## ── Text window ────────────────────────────────────────────────────
define gui.textbox_height = 285
define gui.textbox_yalign = 1.0

## A solid panel behind the dialogue. ~82% opacity so faint art under
## it still breathes through.
define gui.textbox_background = Solid("#0a0f14d2")

## ── Dialogue body ──────────────────────────────────────────────────
define gui.text_color = "#f0ebe0"
define gui.text_font = "DejaVuSans.ttf"
define gui.text_size = 24
define gui.text_xpos = 280
define gui.text_ypos = 60
define gui.text_width = 1360
define gui.text_outlines = [(1, "#000000a0", 0, 0)]
define gui.text_line_spacing = 4

## ── Speaker name tag ──────────────────────────────────────────────
define gui.name_text_color = "#c4a882"
define gui.name_text_size = 26
define gui.name_text_xpos = 80
define gui.name_text_ypos = 60
define gui.name_text_xalign = 0.0

## Thin accent bar between name column and dialogue body
image namebar = Solid("#c4a88266", xsize=3, ysize=180)

## ── Choice menu ───────────────────────────────────────────────────
define gui.choice_button_width = 980
define gui.choice_button_height = 62
define gui.choice_button_text_size = 22
define gui.choice_button_text_color = "#e0d8c8"
define gui.choice_button_text_hover_color = "#ffe8a0"

## ── Text speed default ─────────────────────────────────────────
## Fonts set via gui.text_font / gui.name_text_font above.
## config.default_font does NOT exist in Ren'Py 8.x — setting it raises
## "not a known configuration variable" at init.
define _preferences.text_cps = 40

## ── Custom say screen ────────────────────────────────────────────
screen say(who, what):
    style_prefix "say"
    window:
        id "window"
        if who is not None:
            window:
                style "namebox"
                text who id "who"
            add "namebar":
                xpos 260
                ypos 50
        text what id "what"

style say_label:
    color gui.name_text_color
    size gui.name_text_size
    xpos gui.name_text_xpos
    ypos gui.name_text_ypos
    font gui.text_font

style say_dialogue:
    color gui.text_color
    size gui.text_size
    xpos gui.text_xpos
    ypos gui.text_ypos
    xsize gui.text_width
    line_spacing gui.text_line_spacing
    font gui.text_font
    outlines gui.text_outlines

style namebox:
    xpos 0
    ypos 0
    xsize 260

style window:
    background gui.textbox_background
    ysize gui.textbox_height
    yalign gui.textbox_yalign
