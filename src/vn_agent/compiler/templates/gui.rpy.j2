define gui.name_text_outlines = [(2, "#000000d8", 0, 0)]

image nameplate_bg = Frame(Solid("#0a0f14e8"), 24, 16)

## ── CTC (click-to-continue) indicator ─────────────────────────────
## A small triangle that pulses in the bottom-right corner of the
## textbox when Ren'Py is waiting for input. Procedurally drawn —
## no external asset. The `ATL` block below pulses opacity in a loop.
image ctc:
    Text("▸", color="#e8d49a", size=32, outlines=[(2, "#000000", 0, 0)])
    alpha 0.2
    linear 0.5 alpha 1.0
    linear 0.5 alpha 0.2
    repeat

## ── Punctuation-aware typewriter ──────────────────────────────────
## Ren'Py's {w=N} tag pauses N seconds. A display callback post-
## processes Writer output to insert these automatically around
## strong punctuation, giving the AI's dialogue natural breathing
## without Writer needing to emit timing tags itself.
init python:
    import re
    _PUNCT_PAUSE = [
        (r"\.\.\.", r"...{w=0.45}"),
        (r"([。！？])", r"\1{w=0.35}"),
        (r"([,，])", r"\1{w=0.12}"),
        (r"([.!?])\s+(?=[A-Z])", r"\1{w=0.25} "),
    ]
    def _vn_typewriter_pauses(s):
        for pattern, repl in _PUNCT_PAUSE:
            s = re.sub(pattern, repl, s)
        return s
    config.say_menu_text_filter = _vn_typewriter_pauses

define _preferences.text_cps = 50

## ── Custom say screen ──────────────────────────────────────────────
## Overrides Ren'Py stock to produce:
##   • floating nameplate above the textbox (not inline)
##   • pulsing CTC in bottom-right
##   • gradient backdrop instead of solid panel
screen say(who, what):
    style_prefix "say"

    ## Nameplate — rendered only when there IS a speaker (narration
    ## skips this branch, textbox shows dialogue in solo).
    if who is not None:
        frame:
            style "nameplate_frame"
            xpos 180
            ypos 720  ## sits just above the 300px textbox at ypos 780
            text who id "who" style "nameplate_text"

    ## Textbox panel — gradient backdrop + body text + CTC arrow
    window:
        id "window"
        background "textbox_bg"
        ysize gui.textbox_height
        yalign gui.textbox_yalign

        text what id "what":
            xpos gui.textbox_xpadding
            ypos gui.textbox_ypadding_top
            xsize 1920 - 2 * gui.textbox_xpadding
            size gui.text_size
            color gui.text_color
            line_spacing gui.text_line_spacing
            outlines gui.text_outlines

        add "ctc":
            xalign 0.98
            yalign 0.92

style nameplate_frame:
    background "nameplate_bg"
    padding (28, 14)

style nameplate_text:
    color gui.name_text_color
    size gui.name_text_size
    outlines gui.name_text_outlines
    font gui.name_text_font

