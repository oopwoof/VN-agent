## GUI Configuration — {{ script.title }}
## Generated by VN-Agent
##
## Design principles (user brief, Sprint 12-3d):
##   1. Readability first — gradient panel at bottom, not a hard rectangle;
##      gentle top fade so BG/sprite breathes through; line-height 1.6×.
##   2. Speaker identity — name tag floats ABOVE the textbox in its own
##      pill; speaker color comes from the Character(color=...) define.
##   3. Pacing — typewriter with punctuation-aware pauses; CTC arrow at
##      bottom-right pulses when Ren'Py is waiting for a click.
##   4. Diegetic minimum — no heavy chrome; backdrop is the speaker's
##      own color tint at very low alpha, so the UI feels theme-aware
##      without a bespoke frame per genre.

init python:
    config.name = "{{ script.title | renpy_safe }}"
    config.version = "1.0"
    config.window_title = "{{ script.title | renpy_safe }}"

## ── Layout ─────────────────────────────────────────────────────────
define gui.textbox_height = 300
define gui.textbox_yalign = 1.0
define gui.textbox_xpadding = 180
define gui.textbox_ypadding_top = 70
define gui.textbox_ypadding_bottom = 50

## Textbox backdrop — single flat dark panel at ~80% alpha. Originally
## this was a 3-band Composite for a gradient effect; in practice the
## discrete alpha steps looked like two horizontal lines crossing the
## panel rather than a smooth fade. One uniform Solid reads cleaner
## and plays better with the sprite above (no visual interference).
image textbox_bg = Solid("#0a0f14cc", xsize=1920, ysize=300)

## ── Dialogue body ──────────────────────────────────────────────────
define gui.text_color = "#f2ecdc"
define gui.text_font = "DejaVuSans.ttf"
define gui.text_size = 26
define gui.text_line_spacing = 6
## Soft glow outline so light-colored text stays legible over bright BGs
define gui.text_outlines = [(2, "#000000c8", 0, 0)]

## ── Speaker nameplate ──────────────────────────────────────────────
## Floats ABOVE the textbox in its own pill — physically separated from
## the dialogue body per the brief's "independent nameplate" principle.
## Width auto-sizes to content.
define gui.name_text_font = "DejaVuSans.ttf"
define gui.name_text_size = 28
define gui.name_text_color = "#e8d49a"
define gui.name_text_outlines = [(2, "#000000d8", 0, 0)]

image nameplate_bg = Frame(Solid("#0a0f14e8"), 24, 16)

## ── CTC (click-to-continue) indicator ─────────────────────────────
## A small triangle that pulses in the bottom-right corner of the
## textbox when Ren'Py is waiting for input. Procedurally drawn —
## no external asset. The `ATL` block below pulses opacity in a loop.
image ctc:
    Text("▸", color="#e8d49a", size=32, outlines=[(2, "#000000", 0, 0)])
    alpha 0.2
    linear 0.5 alpha 1.0
    linear 0.5 alpha 0.2
    repeat

## ── Punctuation-aware typewriter ──────────────────────────────────
## Ren'Py's {w=N} tag pauses N seconds. A display callback post-
## processes Writer output to insert these automatically around
## strong punctuation, giving the AI's dialogue natural breathing
## without Writer needing to emit timing tags itself.
init python:
    import re
    _PUNCT_PAUSE = [
        (r"\.\.\.", r"...{w=0.45}"),
        (r"([。！？])", r"\1{w=0.35}"),
        (r"([,，])", r"\1{w=0.12}"),
        (r"([.!?])\s+(?=[A-Z])", r"\1{w=0.25} "),
    ]
    def _vn_typewriter_pauses(s):
        for pattern, repl in _PUNCT_PAUSE:
            s = re.sub(pattern, repl, s)
        return s
    config.say_menu_text_filter = _vn_typewriter_pauses

define _preferences.text_cps = 50

## ── Custom say screen ──────────────────────────────────────────────
## Overrides Ren'Py stock to produce:
##   • floating nameplate above the textbox (not inline)
##   • pulsing CTC in bottom-right
##   • gradient backdrop instead of solid panel
screen say(who, what):
    style_prefix "say"

    ## Nameplate — rendered only when there IS a speaker (narration
    ## skips this branch, textbox shows dialogue in solo).
    if who is not None:
        frame:
            style "nameplate_frame"
            xpos 180
            ypos 720  ## sits just above the 300px textbox at ypos 780
            text who id "who" style "nameplate_text"

    ## Textbox panel — flat backdrop + body text + CTC arrow.
    ## Geometry is set via the NAMED `say_window` style below. Previous
    ## iteration used `style window is default:` which was a global
    ## override — it stripped backgrounds from save/load/preferences
    ## screens too, making the dialog box look "disappeared" along
    ## with every other built-in menu. `say_window` is scoped.
    window:
        id "window"
        style "say_window"
        background "textbox_bg"

        text what id "what":
            ## xpos/ypos here are inside the window's local coord
            ## system (0,0 = window's top-left = screen (0, 780)).
            xpos gui.textbox_xpadding
            ypos gui.textbox_ypadding_top
            xmaximum 1920 - 2 * gui.textbox_xpadding
            size gui.text_size
            color gui.text_color
            line_spacing gui.text_line_spacing
            outlines gui.text_outlines

        add "ctc":
            xpos 1860
            ypos 240

## ── Scoped say-window style (Bug 1 fix) ───────────────────────────
## Inherits from `window` but overrides only the properties we care
## about for the dialogue textbox. Crucially this does NOT touch the
## base `window` style, so save/load/preferences keep their stock
## Ren'Py chrome. Previous approach used `style window is default` which
## clobbered all those other menus simultaneously.
style say_window is window:
    background None
    xpos 0
    ypos 780
    xsize 1920
    ysize gui.textbox_height
    xalign 0.0
    yalign 0.0
    xfill False
    yfill False
    padding (0, 0, 0, 0)
    margin (0, 0, 0, 0)

## ── Custom choice screen ───────────────────────────────────────────
## Player-facing branches render as floating buttons stacked in the
## middle of the screen, NOT inside the dialogue box. The backdrop
## dims to ~50% so focus jumps to the choices without hiding the
## scene entirely (player remembers what prompted the decision).
screen choice(items):
    style_prefix "vn_choice"

    ## Scene dimmer — a full-screen low-alpha solid that kills
    ## distraction without blacking out the BG entirely.
    add Solid("#000000a0")

    ## Choice stack, vertically centered. Works for 2-4 items cleanly;
    ## 5+ would want a scroll viewport (rare in VN design).
    vbox:
        xalign 0.5
        yalign 0.5
        spacing 28

        for i in items:
            textbutton i.caption:
                action i.action
                style "vn_choice_button"

style vn_choice_button is default:
    background Frame(Solid("#1a2030e8"), 40, 20)
    hover_background Frame(Solid("#3a4a70f0"), 40, 20)
    padding (48, 22)
    xsize 900
    xalign 0.5

style vn_choice_button_text is default:
    font gui.text_font
    size 28
    color "#e8d49a"
    hover_color "#ffe8a0"
    outlines [(2, "#000000d8", 0, 0)]
    xalign 0.5
    text_align 0.5

style nameplate_frame:
    background "nameplate_bg"
    padding (28, 14)

style nameplate_text:
    color gui.name_text_color
    size gui.name_text_size
    outlines gui.name_text_outlines
    font gui.name_text_font

## NOTE: the legacy gui.choice_button_* defines are intentionally omitted.
## Our custom `screen choice` above uses the vn_choice_button style block
## directly, so Ren'Py's default menu screen (which reads gui.choice_*)
## is never invoked. Keeps the GUI source a single source of truth.
